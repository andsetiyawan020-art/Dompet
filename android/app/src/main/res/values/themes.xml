<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        NoActionBar: WebView mengambil seluruh layar.
        App sudah punya header sendiri di dalam HTML.
    -->
    <style name="Theme.SaldoTracker" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <!-- Warna background window saat loading — sama dengan splash screen -->
        <item name="android:windowBackground">@color/ic_launcher_background</item>
        <item name="android:statusBarColor">@color/colorPrimaryDark</item>
    </style>
</resources>
