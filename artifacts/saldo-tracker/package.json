{
  "name": "@workspace/saldo-tracker",
  "version": "1.0.0",
  "description": "Aplikasi pencatatan saldo harian — catat pengeluaran, hitung pendapatan otomatis",
  "private": true,
  "type": "module",
  "scripts": {
    "dev":       "vite --config vite.config.ts --host 0.0.0.0",
    "build":     "vite build --config vite.config.ts",
    "build:apk": "vite build --config vite.config.ts --base ./",
    "serve":     "vite preview --config vite.config.ts --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@replit/vite-plugin-cartographer": "catalog:",
    "@replit/vite-plugin-dev-banner":   "catalog:",
    "@types/node":                      "catalog:",
    "typescript":                       "~5.9.3",
    "vite":                             "catalog:"
  }
}
